{
  "expo": {
    "name": "Adventure Book",
    "slug": "AdventureBook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "adventurebook",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.rovey.AdventureBook",
      "infoPlist": {
        "NSCameraUsageDescription": "Adventure Book uses the camera so families can capture real-world discoveries together.",
        "NSMicrophoneUsageDescription": "Adventure Book uses the microphone for video and voice memo discoveries.",
        "NSLocationWhenInUseUsageDescription": "Adventure Book can save where a discovery happened."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.rovey.AdventureBook",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Adventure Book to access your camera for discoveries.",
          "microphonePermission": "Allow Adventure Book to access your microphone for video and voice discoveries.",
          "recordAudioAndroid": true,
          "barcodeScannerEnabled": false
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Adventure Book to access your microphone for voice memo discoveries.",
          "recordAudioAndroid": true,
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Adventure Book to save where discoveries happen."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
